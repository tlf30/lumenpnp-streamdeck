#!/usr/bin/env bash
# Start or restart the Stream Deck controller (installed package).
set -euo pipefail

INSTALL_ROOT="/usr/lib/streamdeck"
PYTHON="${INSTALL_ROOT}/.venv/bin/python"

if [ ! -x "${PYTHON}" ]; then
  echo "Stream Deck Python environment missing. Reinstall streamdeck-openpnp." >&2
  exit 1
fi

if ! compgen -G "/etc/udev/rules.d/*streamdeck*" >/dev/null && \
   ! grep -qs '0fd9' /etc/udev/rules.d/*.rules 2>/dev/null; then
  echo "Missing udev rule for Stream Deck USB access. Reinstall streamdeck-openpnp." >&2
  exit 1
fi

for hid in /dev/hidraw*; do
  if udevadm info -a -n "$hid" 2>/dev/null | grep -q 'ATTRS{idVendor}=="0fd9"'; then
    if [ ! -r "$hid" ] || [ ! -w "$hid" ]; then
      echo "Cannot access $hid — replug the deck or log out/in after install." >&2
      exit 1
    fi
    break
  fi
done

pkill -f "[p]ython -m streamdeck_app.controller" 2>/dev/null || true
sleep 0.2
cd "${INSTALL_ROOT}"
export PYTHONPATH="${INSTALL_ROOT}"
exec "${PYTHON}" -m streamdeck_app.controller